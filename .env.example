# ── LLM Providers ──────────────────────────────────────────────────────────────
# Primary: Anthropic Claude (required)
ANTHROPIC_API_KEY=sk-ant-...

# Optional fallback via OpenRouter (200+ models)
OPENROUTER_API_KEY=sk-or-...

# ── Messaging Gateways ─────────────────────────────────────────────────────────
# Telegram bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Discord bot
DISCORD_BOT_TOKEN=

# ── CRM Integrations ───────────────────────────────────────────────────────────
# HubSpot
HUBSPOT_API_KEY=

# Salesforce
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_DOMAIN=login

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_FILE=~/.salespossible/google_credentials.json

# ── Search ────────────────────────────────────────────────────────────────────
# DuckDuckGo is used by default (no key needed)
# Optionally provide SerpAPI for richer results
SERPAPI_KEY=

# ── Agent Settings ─────────────────────────────────────────────────────────────
AGENT_NAME=Alex
AGENT_DATA_DIR=~/.salespossible
AGENT_LOG_LEVEL=INFO
