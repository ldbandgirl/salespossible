# ---- Hermes Agent (your Hostinger VPS) ----
# Public HTTPS URL of your Hermes Agent API server (see README: "Expose Hermes on Hostinger")
HERMES_BASE_URL=https://hermes.example.com
# Must match API_SERVER_KEY in ~/.hermes/.env on the VPS
HERMES_API_KEY=change-me
# Advertised model name (defaults to hermes-agent)
HERMES_MODEL=hermes-agent
# auto | responses | chat  ("auto" tries /v1/responses for server-side memory,
# falls back to /v1/chat/completions)
HERMES_MODE=auto
# Named conversation for server-side continuity (responses mode)
HERMES_CONVERSATION=reachy-mini
# Vision: off | auto (send camera when you ask to look/see) | always
# Requires the model behind Hermes to accept image input.
VISION_MODE=auto

# ---- Speech to text (hearing) ----
# groq (free, recommended) | minimax (experimental) | openai
# MiniMax has no reliable public ASR, so hearing defaults to Groq's free tier.
STT_PROVIDER=groq
GROQ_API_KEY=
OPENAI_API_KEY=
# Optional: force a language code like "en" (empty = auto-detect)
STT_LANGUAGE=

# ---- Text to speech (voice) ----
# minimax (Token Plan key covers this) | elevenlabs | openai
TTS_PROVIDER=minimax
# MiniMax — one key also powers your Hermes brain; Token Plan key works for TTS
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_VOICE_ID=Wise_Woman
# ElevenLabs / OpenAI (only if you pick those providers)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
TTS_VOICE=alloy
